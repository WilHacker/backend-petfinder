{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "prisma/**/*.prisma", "watchAssets": true },
      { "include": "assets/**/*", "watchAssets": true }
    ],
    "manualRestart": true
  },
  "generateOptions": {
    "spec": true,
    "flat": false
  }
}